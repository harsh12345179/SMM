<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Content Marketing | Nice & Next StyleUp</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:#f8f9fa;
    color:#333;
    line-height:1.6;
}

/* HEADER */
header{
    background:linear-gradient(to right,#2c3e50,#34495e);
    padding:40px;
    text-align:center;
    color:white;
}

header h1{
    font-size:42px;
    font-weight:700;
    letter-spacing:2px;
}

header p{
    margin-top:10px;
    font-size:20px;
    font-weight:300;
}

/* SECTION */
section{
    padding:60px 10%;
}

/* ABOUT */
.about{
    display:flex;
    flex-wrap:wrap;
    align-items:center;
    gap:40px;
    justify-content:center;
}

.about img{
    width:400px;
    height:auto;
    border-radius:15px;
    box-shadow:0 15px 35px rgba(0,0,0,0.2);
}

.about-text{
    max-width:600px;
}

.about-text h2{
    font-size:36px;
    margin-bottom:20px;
    font-weight:600;
    color:#2c3e50;
}

.about-text p{
    font-size:18px;
    color:#555;
    line-height:1.8;
}

/* EXPERIENCE */
.experience{
    background:#fff;
    text-align:center;
}

.experience h2{
    font-size:32px;
    margin-bottom:30px;
    font-weight:600;
    color:#2c3e50;
}

.exp-box{
    display:flex;
    justify-content:center;
    gap:30px;
    flex-wrap:wrap;
    margin-top:40px;
}

.exp{
    background:#111;
    color:white;
    width:220px;
    padding:30px;
    border-radius:15px;
    box-shadow:0 10px 20px rgba(0,0,0,0.2);
    transition: transform 0.3s ease-in-out;
}

.exp:hover{
    transform:scale(1.05);
}

.exp h3{
    font-size:40px;
    color:#f1c40f;
}

.exp p{
    font-size:16px;
}

/* CONTENT STRATEGY */
.strategy{
    background:linear-gradient(120deg,#ece9e6,#ffffff);
    padding:60px 0;
}

.strategy h2{
    text-align:center;
    font-size:36px;
    margin-bottom:40px;
    font-weight:600;
    color:#2c3e50;
}

.cards{
    display:flex;
    gap:30px;
    justify-content:center;
    flex-wrap:wrap;
}

.card{
    background:white;
    width:280px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
    overflow:hidden;
    transition: transform 0.3s ease;
}

.card:hover{
    transform:scale(1.05);
}

.card img{
    width:100%;
    height:180px;
    object-fit:cover;
}

.card h3{
    padding:15px;
    font-size:22px;
    color:#2c3e50;
    font-weight:600;
}

.card p{
    padding:0 15px 20px;
    font-size:16px;
    color:#555;
}

/* ONLINE PRESENCE */
.online{
    text-align:center;
    padding:60px 10%;
    background:#f9f9f9;
}

.online h2{
    font-size:36px;
    margin-bottom:20px;
    font-weight:600;
    color:#2c3e50;
}

.online p{
    max-width:800px;
    margin:auto;
    font-size:18px;
    color:#555;
}

/* FOOTER */
footer{
    background:#2c3e50;
    color:white;
    text-align:center;
    padding:25px;
}

footer a{
    color:#f1c40f;
    margin:0 10px;
    text-decoration:none;
    font-weight:600;
    font-size:18px;
    transition: color 0.3s ease;
}

footer a:hover{
    color:white;
}
</style>
</head>

<body>

<header>
    <h1>Content Marketing</h1>
    <p>Nice & Next StyleUp – Unisex Fashion Brand</p>
</header>

<!-- ABOUT BRAND -->
<section class="about">
    <img src="https://images.unsplash.com/photo-1520975922138-bc1b6c0f6f21" alt="Fashion Image">
    <div class="about-text">
        <h2>Our Fashion Story</h2>
        <p>
            Nice & Next StyleUp is a unisex fashion brand built for the modern digital world.
            We focus on content-driven marketing that connects style with confidence.
            Our brand voice is bold, inclusive, and trend-forward, helping customers
            discover fashion through engaging online content.
        </p>
    </div>
</section>

<!-- EXPERIENCE -->
<section class="experience">
    <h2>Our Experience</h2>
    <div class="exp-box">
        <div class="exp">
            <h3>7+</h3>
            <p>Years in Fashion Industry</p>
        </div>
        <div class="exp">
            <h3>20K+</h3>
            <p>Online Customers</p>
        </div>
        <div class="exp">
            <h3>150+</h3>
            <p>Content Campaigns</p>
        </div>
        <div class="exp">
            <h3>50+</h3>
            <p>Influencer Collaborations</p>
        </div>
    </div>
</section>

<!-- CONTENT STRATEGY -->
<section class="strategy">
    <h2>Our Content Marketing Strategy</h2>
    <div class="cards">
        <div class="card">
            <img src="https://via.placeholder.com/260x180" alt="Visual Storytelling">
            <h3>Visual Storytelling</h3>
            <p>High-quality images & videos showcasing unisex fashion trends.</p>
        </div>

        <div class="card">
            <img src="https://via.placeholder.com/260x180" alt="Social Media Content">
            <h3>Social Media Content</h3>
            <p>Instagram reels, YouTube shorts, and brand storytelling.</p>
        </div>

        <div class="card">
            <img src="https://via.placeholder.com/260x180" alt="Customer Engagement">
            <h3>Customer Engagement</h3>
            <p>Interactive posts, polls, reviews, and community-driven fashion.</p>
        </div>
    </div>
</section>

<!-- ONLINE PRESENCE -->
<section class="online">
    <h2>Our Online Identity</h2>
    <p>
        Nice & Next StyleUp uses content marketing to build trust, brand awareness,
        and customer loyalty. Through consistent online content, we promote
        unisex fashion that fits every personality and lifestyle.
    </p>
</section>

<footer>
    <p>© 2026 Nice & Next StyleUp | Content Marketing</p>
    <p>
        <a href="#">Instagram</a>
        <a href="#">Facebook</a>
        <a href="#">YouTube</a>
    </p>
</footer>

</body>
</html>
