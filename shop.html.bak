<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>StyleUp Premium Shop</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>

/* ========= RESET ========= */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI', sans-serif;
}

body{
    background:#f6f7fb;
}

/* ========= HEADER ========= */
.header{
    background:#1f2937;
    color:white;
    padding:15px 40px;
    display:flex;
    align-items:center;
    justify-content:space-between;
}

.logo{
    font-size:22px;
    font-weight:bold;
}

.search-area{
    flex:1;
    display:flex;
    margin:0 30px;
}

.search-area input{
    flex:1;
    padding:10px;
    border:none;
    border-radius:25px 0 0 25px;
}

.search-area button{
    padding:10px 20px;
    background:#fbbf24;
    border:none;
    border-radius:0 25px 25px 0;
    cursor:pointer;
}

.cart{
    cursor:pointer;
    font-weight:bold;
}

/* ========= BANNER ========= */
.banner{
    height:220px;
    background:linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.6)),
    url("https://images.unsplash.com/photo-1483985988355-763728e1935b") center/cover;
    display:flex;
    justify-content:center;
    align-items:center;
    color:white;
    font-size:32px;
}

/* ========= PRODUCTS ========= */
.section-title{
    padding:25px 40px 10px;
    font-size:26px;
    font-weight:bold;
}

.products{
    padding:0 40px 50px;
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
    gap:25px;
}

.product{
    background:white;
    border-radius:12px;
    box-shadow:0 5px 15px rgba(0,0,0,.12);
    overflow:hidden;
    text-align:center;
    transition:.3s;
}

.product:hover{
    transform:translateY(-6px);
}

.product img{
    width:100%;
    height:200px;
    object-fit:cover;
}

.product-info{
    padding:15px;
}

.price{
    color:#e11d48;
    font-weight:bold;
}

.product button{
    margin-top:10px;
    padding:8px 18px;
    border:none;
    background:#1f2937;
    color:white;
    border-radius:20px;
    cursor:pointer;
}

/* ========= ROCKET ANIMATION ========= */
.rocket{
    position:fixed;
    font-size:26px;
    z-index:9999;
    transition:all 0.8s ease-in-out;
}

/* ========= CART MODAL ========= */
.cart-modal{
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,.6);
    justify-content:center;
    align-items:center;
}

.cart-box{
    background:white;
    width:340px;
    padding:20px;
    border-radius:10px;
}

.close{
    float:right;
    cursor:pointer;
    color:red;
}

.cart-item{
    font-size:14px;
    margin:6px 0;
}

.total{
    font-weight:bold;
    margin-top:10px;
}

.delivery{
    font-size:13px;
    color:#555;
}

/* ========= FOOTER ========= */
.footer{
    background:#1f2937;
    color:white;
    text-align:center;
    padding:20px;
}

</style>
</head>

<body>

<!-- HEADER -->
<div class="header">
    <div class="logo">Nice & Next StyleUp</div>

    <div class="search-area">
        <input id="searchInput" placeholder="Search fashion...">
        <button onclick="searchProducts()">Search</button>
    </div>

    <div class="cart" id="cartBtn" onclick="openCart()">
        Cart 🛒 (<span id="cartCount">0</span>)
    </div>
</div>

<!-- BANNER -->
<div class="banner">🔥 Premium Fashion Sale</div>

<div class="section-title">Trending Products</div>

<div class="products" id="grid">

    <div class="product" data-name="Jacket">
        <img src="https://images.unsplash.com/photo-1483985988355-763728e1935b">
        <div class="product-info">
            <h4>Casual Jacket</h4>
            <div class="price">$29</div>
            <button onclick="addToCart(event,'Casual Jacket',29)">Add to Cart</button>
        </div>
    </div>

    <div class="product" data-name="Hoodie">
        <img src="https://images.unsplash.com/photo-1520975922323-6d2f45b9b6ae">
        <div class="product-info">
            <h4>Street Hoodie</h4>
            <div class="price">$35</div>
            <button onclick="addToCart(event,'Street Hoodie',35)">Add to Cart</button>
        </div>
    </div>

    <div class="product" data-name="Dress">
        <img src="https://images.unsplash.com/photo-1495121605193-b116b5b09a13">
        <div class="product-info">
            <h4>Modern Dress</h4>
            <div class="price">$39</div>
            <button onclick="addToCart(event,'Modern Dress',39)">Add to Cart</button>
        </div>
    </div>

</div>

<!-- CART MODAL -->
<div class="cart-modal" id="cartModal">
    <div class="cart-box">
        <span class="close" onclick="closeCart()">X</span>
        <h3>Your Cart</h3>
        <div id="cartItems"></div>
        <div class="total" id="totalPrice"></div>
        <div class="delivery" id="deliveryDate"></div>
    </div>
</div>

<div class="footer">© 2026 Nice & Next StyleUp</div>

<script>

/* ===== CART DATA ===== */
let cart = [];

/* ===== ADD TO CART WITH ROCKET ===== */
function addToCart(e,name,price){

    // rocket animation
    const rocket = document.createElement("div");
    rocket.className="rocket";
    rocket.innerText="🚀";
    document.body.appendChild(rocket);

    let start = e.target.getBoundingClientRect();
    let cartBtn = document.getElementById("cartBtn").getBoundingClientRect();

    rocket.style.left=start.left+"px";
    rocket.style.top=start.top+"px";

    setTimeout(()=>{
        rocket.style.left=cartBtn.left+"px";
        rocket.style.top=cartBtn.top+"px";
    },50);

    setTimeout(()=>rocket.remove(),800);

    cart.push({name,price});
    document.getElementById("cartCount").innerText=cart.length;
}

/* ===== OPEN CART ===== */
function openCart(){

    let html="";
    let total=0;

    cart.forEach(i=>{
        html += `<div class="cart-item">${i.name} - $${i.price}</div>`;
        total+=i.price;
    });

    document.getElementById("cartItems").innerHTML = html || "Cart empty";
    document.getElementById("totalPrice").innerText="Total: $"+total;

    let d = new Date();
    d.setDate(d.getDate()+5);
    document.getElementById("deliveryDate").innerText=
        "📦 Delivery by: "+d.toDateString();

    document.getElementById("cartModal").style.display="flex";
}

function closeCart(){
    document.getElementById("cartModal").style.display="none";
}

/* ===== SEARCH ===== */
function searchProducts(){
    let input=document.getElementById("searchInput").value.toLowerCase();
    document.querySelectorAll(".product").forEach(p=>{
        let name=p.dataset.name.toLowerCase();
        p.style.display=name.includes(input)?"block":"none";
    });
}

</script>

</body>
</html>
