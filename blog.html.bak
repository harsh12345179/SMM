<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Nice & Next StyleUp | Fashion Store & Support</title>

<meta name="description"
content="Shop trendy fashion at affordable prices and get fast customer support. Nice & Next StyleUp offers quality clothes with easy help & service.">

<style>

/* ===== RESET ===== */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI', sans-serif;
}

body{
    background:#f4f6fa;
    line-height:1.7;
}

/* ===== HEADER ===== */
header{
    background:#2c3e50;
    color:white;
    padding:15px 40px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    position:sticky;
    top:0;
}

nav a{
    color:white;
    margin-left:20px;
    text-decoration:none;
}
nav a:hover{ color:#f1c40f; }

/* ===== HERO ===== */
.hero{
    height:70vh;
    background:linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.6)),
    url("https://images.unsplash.com/photo-1483985988355-763728e1935b") center/cover;
    display:flex;
    justify-content:center;
    align-items:center;
    color:white;
    text-align:center;
}

.hero h1{font-size:48px;}
.hero p{margin:15px 0;font-size:20px;}

.hero button{
    padding:14px 30px;
    background:#f1c40f;
    border:none;
    border-radius:30px;
    cursor:pointer;
}

/* ===== COMMON ===== */
.section{
    padding:80px 60px;
    text-align:center;
}

.cards{
    display:flex;
    gap:30px;
    justify-content:center;
    flex-wrap:wrap;
}

/* ===== PRODUCTS ===== */
.card{
    background:white;
    width:270px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,0.15);
    overflow:hidden;
    transition:.3s;
}
.card:hover{ transform:translateY(-8px); }

.card img{
    width:100%;
    height:200px;
    object-fit:cover;
}

.card h3{margin:10px;}
.card p{padding:0 10px 10px;}

/* ===== HELP SUPPORT ===== */
.support{
    background:#2c3e50;
    color:white;
}

.support-box{
    background:#34495e;
    width:280px;
    padding:30px;
    border-radius:15px;
    transition:.3s;
}

.support-box:hover{
    transform:scale(1.05);
    background:#3f5b78;
}

.support h3{
    margin-bottom:10px;
}

/* ===== FAQ ===== */
.faq{
    text-align:left;
    max-width:900px;
    margin:0 auto;
}

.faq h4{
    margin-top:20px;
    color:#2c3e50;
}

/* ===== FOOTER ===== */
footer{
    background:#2c3e50;
    color:white;
    text-align:center;
    padding:30px;
}

.social{
    margin-top:15px;
    display:flex;
    justify-content:center;
    gap:20px;
}

.social a{
    padding:10px 25px;
    border-radius:25px;
    text-decoration:none;
    color:white;
    font-weight:bold;
}

.fb{background:#1877f2;}
.ig{background:linear-gradient(45deg,#f58529,#dd2a7b,#8134af,#515bd4);}

</style>
</head>

<body>

<!-- HEADER -->
<header>
    <h2>Nice & Next StyleUp</h2>
    <nav>
        <a href="#">Home</a>
        <a href="#">Shop</a>
        <a href="#support">Help & Support</a>
        <a href="#">Contact</a>
    </nav>
</header>

<!-- HERO -->
<section class="hero">
    <div>
        <h1>Buy Trendy Fashion Clothes Online at Affordable Price</h1>
        <p>Modern style • Best prices • Fast delivery</p>
        <button>Shop Now</button>
    </div>
</section>

<!-- PRODUCTS -->
<section class="section">
    <h2>Featured Collections</h2>

    <div class="cards">
        <div class="card">
            <img src="https://images.unsplash.com/photo-1512436991641-6745cdb1723f">
            <h3>Street Style</h3>
            <p>Casual & trending outfits</p>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1495121605193-b116b5b09a13">
            <h3>Modern Wear</h3>
            <p>Premium everyday fashion</p>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1520975922323-6d2f45b9b6ae">
            <h3>Party Collection</h3>
            <p>Bold & stylish looks</p>
        </div>
    </div>
</section>

<!-- HELP & SUPPORT SECTION -->
<section class="support section" id="support">

    <h2>Help & Support Center</h2>
    <p>We’re here to help you anytime</p>

    <div class="cards" style="margin-top:40px;">

        <div class="support-box">
            <h3>📞 Call Us</h3>
            <p>+91 98765 43210</p>
            <p>Mon–Sat 9AM–8PM</p>
        </div>

        <div class="support-box">
            <h3>💬 Live Chat</h3>
            <p>Instant help from our team</p>
            <p>Quick responses</p>
        </div>

        <div class="support-box">
            <h3>📧 Email Support</h3>
            <p>support@styleup.com</p>
            <p>Reply within 24 hrs</p>
        </div>

    </div>
</section>

<!-- FAQ -->
<section class="section faq">
    <h2>Frequently Asked Questions</h2>

    <h4>How long does delivery take?</h4>
    <p>Orders usually arrive within 3–5 business days.</p>

    <h4>Can I return products?</h4>
    <p>Yes, easy 7-day return policy available.</p>

    <h4>Are clothes affordable?</h4>
    <p>Yes! We focus on trendy fashion at affordable prices for everyone.</p>
</section>

<!-- FOOTER -->
<footer>
    <p>© 2026 Nice & Next StyleUp</p>

    <div class="social">
        <a href="https://facebook.com" target="_blank" class="fb">Facebook</a>
        <a href="https://instagram.com" target="_blank" class="ig">Instagram</a>
    </div>
</footer>

</body>
</html>
